@charset "utf-8";

* { box-sizing: border-box; margin: 0px; padding: 0px; }

body { min-height: 100vh; font-family: Arial, sans-serif; background: linear-gradient(rgb(255, 245, 248) 0%, rgb(255, 231, 239) 100%); color: rgb(61, 34, 48); display: flex; align-items: center; justify-content: center; padding: 24px; overflow-x: hidden; }

.container { width: 100%; max-width: 430px; background: rgba(255, 255, 255, 0.88); border-radius: 24px; padding: 24px; box-shadow: rgba(120, 62, 86, 0.18) 0px 20px 60px; text-align: center; position: relative; overflow: hidden; }

.photo { width: 100%; border-radius: 20px; display: block; object-fit: cover; box-shadow: rgba(0, 0, 0, 0.12) 0px 12px 32px; position: relative; z-index: 2; }

h1 { margin: 18px 0px 10px; font-size: 30px; }

p { color: rgb(107, 74, 89); margin-bottom: 18px; line-height: 1.5; }

button { border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; background: rgb(229, 75, 122); color: white; padding: 14px 24px; border-radius: 999px; font-size: 16px; font-weight: 700; cursor: pointer; box-shadow: rgba(229, 75, 122, 0.35) 0px 10px 24px; }

button:hover { background: rgb(207, 57, 104); }

.hidden { display: none; }

.message { margin-top: 20px; font-size: 28px; font-weight: bold; color: rgb(196, 45, 102); position: relative; z-index: 2; }

.rain { position: absolute; inset: 0px; pointer-events: none; overflow: hidden; z-index: 1; }

.drop { position: absolute; top: -120px; width: 2px; height: 90px; background: linear-gradient(rgba(255, 255, 255, 0), rgba(120, 180, 255, 0.9)); animation: auto linear 0s infinite normal none running rain; opacity: 0.75; }

@keyframes rain { 
  0% { transform: translateY(-80px); }
  100% { transform: translateY(620px); }
}
